# Azure AD app registration for real Microsoft Graph sending.
# Local dev: copy this file to ".env.local" and fill in your values.
# Production: set these in Vercel → Settings → Environment Variables.
#
# The Azure app registration must be a "Single-page application" (SPA) with the
# deployed origin as a redirect URI, and delegated Graph permissions
# Mail.Send + User.Read.

VITE_AZURE_CLIENT_ID=your-application-client-id
VITE_AZURE_TENANT_ID=your-directory-tenant-id
